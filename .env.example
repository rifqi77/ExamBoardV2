APP_NAME="Exam Dashboard"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=secure_exam
# Use a least-privilege account, NOT root — run database/sql/create-db-user.sql
DB_USERNAME=examboard
DB_PASSWORD=

SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
# Set true in PRODUCTION (behind HTTPS) so auth/exam cookies are TLS-only.
SESSION_SECURE_COOKIE=false

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
# 'database' runs AI generation/grading async (needs the queue worker — see
# docs/OPERATIONS.md). Use 'sync' to run them inline (no worker, but requests block).
QUEUE_CONNECTION=database

CACHE_STORE=file
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# --- Exam Dashboard specifics ---
# REQUIRED: HS256 secret for the session + exam-access JWT cookies (>= 32 chars).
# Generate one:  php -r "echo bin2hex(random_bytes(33));"
# To run alongside the Next.js app on the same database, copy ITS SESSION_SECRET
# verbatim so the two share sessions.
SESSION_SECRET=
SESSION_COOKIE_NAME="secure-exam-session"

# Optional: explicit mysqldump path for `php artisan db:backup`
# (auto-detected as C:\xampp\mysql\bin\mysqldump.exe on Windows).
# DB_DUMP_BINARY=

# Optional: operational alerts on server errors (5xx) and AI failures.
# Best-effort + deduped; the app always logs regardless. A webhook with a
# {"text": "..."} payload (Slack/Discord/Telegram-compatible) is simplest:
# ALERT_WEBHOOK_URL=
# ALERT_EMAIL=                 # also email (needs a real MAIL_MAILER, not 'log')
# ALERT_THROTTLE_MINUTES=10    # dedupe identical alerts

# AI provider keys are stored ENCRYPTED in the database (Admin -> AI settings),
# not here. These env fallbacks are optional:
# GEMINI_API_KEY=
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
